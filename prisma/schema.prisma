generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL")
}

model User {
  id                      String                     @id @default(cuid())
  email                   String                     @unique
  stripeCustomerId        String?                    @unique
  stripeSubscriptionId    String?
  planCode                String                     @default("FREE")
  planRenewsAt            DateTime?
  extraCredits            Json                       @default("{}")
  tokens                  Int                        @default(30)
  resetDate               DateTime                   @default(now())
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  communityUsed           Int                        @default(0)
  instagramHandle         String?
  location                String?
  name                    String?
  nickname                String?
  profileIcon             String?                    @default("👤")
  backgroundTheme         String?                    @default("neutral-1")
  communityImages         CommunityImage[]
  saved_cars              saved_cars[]
  saved_images            saved_images[]
  saved_performance       saved_performance?
  turboTycoonState        TurboTycoonState?
  turboFactoryProgresses  TurboFactoryProgress[]
  turboResearchOwnership  TurboResearchOwnership[]
  turboTokenConversions   TurboTokenConversion[]

  @@map("users")
}

model CommunityImage {
  id          String               @id @default(cuid())
  userEmail   String
  imageUrl    String
  description String?
  approved    Boolean              @default(false)
  likesCount  Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  likes       CommunityImageLike[]
  user        User                 @relation(fields: [userEmail], references: [email])

  @@map("community_images")
}

model CommunityImageLike {
  id        String         @id @default(cuid())
  imageId   String
  userEmail String
  createdAt DateTime       @default(now())
  image     CommunityImage @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([imageId, userEmail])
  @@map("community_image_likes")
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("verification_codes")
}

model saved_cars {
  id              String   @id
  userEmail       String
  name            String
  make            String
  model           String
  year            String
  trim            String?
  imageUrl        String?
  performanceData Json?
  buildPlanData   Json?
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  users           User     @relation(fields: [userEmail], references: [email])
}

model saved_performance {
  id        String   @id
  userEmail String   @unique
  carInput  Json
  results   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User     @relation(fields: [userEmail], references: [email])

  @@map("saved_performance")
}

model anonymous_users {
  id            String   @id
  fingerprint   String   @unique
  tokens        Int      @default(10)
  communityUsed Int      @default(0)
  resetDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([fingerprint])
}

model promotion_redemptions {
  id          String     @id
  promotionId String
  userEmail   String
  redeemedAt  DateTime   @default(now())
  promotions  promotions @relation(fields: [promotionId], references: [id])

  @@unique([promotionId, userEmail])
}

model promotions {
  id                    String                  @id
  code                  String                  @unique
  planCode              String
  maxUses               Int
  usedCount             Int                     @default(0)
  active                Boolean                 @default(true)
  expiresAt             DateTime?
  createdAt             DateTime                @default(now())
  promotion_redemptions promotion_redemptions[]
}

model saved_images {
  id        String   @id
  userEmail String
  imageUrl  String
  carSpec   Json
  prompt    String
  createdAt DateTime @default(now())
  users     User     @relation(fields: [userEmail], references: [email])
}

model tool_usage {
  id           String   @id
  toolType     String
  userEmail    String?
  fingerprint  String?
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([fingerprint])
  @@index([toolType, createdAt])
  @@index([userEmail])
}

// Turbo Tycoon Game Models
enum TurboFactoryType {
  COMPRESSOR
  TURBO_ASSEMBLY
  ECU_FLASH
}

model TurboTycoonState {
  id               String   @id @default(cuid())
  userEmail        String   @unique
  user             User     @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  totalHp          BigInt   @default(0)
  lifetimeHpEarned BigInt   @default(0)
  lifetimePartsMade BigInt  @default(0)
  lastUpdatedAt    DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("turbo_tycoon_state")
}

model TurboFactoryProgress {
  id                           String           @id @default(cuid())
  userEmail                    String
  user                         User             @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  factoryType                  TurboFactoryType
  isUnlocked                   Boolean          @default(false)
  level                        Int              @default(1)
  totalPartsProduced           BigInt           @default(0)
  currentCycleRemainingSeconds Int              @default(0)
  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime         @updatedAt

  @@unique([userEmail, factoryType])
  @@map("turbo_factory_progress")
}

model TurboResearchOwnership {
  id          String   @id @default(cuid())
  userEmail   String
  user        User     @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  researchKey String
  acquiredAt  DateTime @default(now())

  @@unique([userEmail, researchKey])
  @@map("turbo_research_ownership")
}

model TurboTokenConversion {
  id            String   @id @default(cuid())
  userEmail     String
  user          User     @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  conversionId  String   // 'small', 'medium', or 'large'
  hpSpent       BigInt   // HP cost of this conversion
  tokensEarned  Int      // Tokens received from this conversion
  weekStart     DateTime // Start of the week this conversion occurred (for cap tracking)
  convertedAt   DateTime @default(now())

  @@index([userEmail, weekStart])
  @@map("turbo_token_conversion")
}
